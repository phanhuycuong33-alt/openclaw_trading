#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

if [[ ! -d ".venv" ]]; then
  python3 -m venv .venv
fi

source .venv/bin/activate
pip install -r requirements.txt >/dev/null

first="${1:-openclaw}"
second="${2:-analysis}"

if [[ "$first" == "manager" ]]; then
  if [[ "$second" != "openclaw" ]]; then
    echo "Usage: ./run manager openclaw"
    exit 1
  fi
  exec python manager_control.py
fi

if [[ "$first" != "openclaw" ]]; then
  echo "Usage: ./run openclaw [analysis|trading|telegram]"
  echo "       ./run manager openclaw"
  echo "Manager env (optional): MANAGER_TELEGRAM_BOT_TOKEN, OPENCLAW_TELEGRAM_BOT_TOKEN"
  exit 1
fi

case "$second" in
  analysis)
    exec python main.py
    ;;
  trading)
    exec python trade_openclaw.py
    ;;
  telegram)
    exec python telegram_control.py
    ;;
  *)
    echo "Usage: ./run openclaw [analysis|trading|telegram]"
    echo "       ./run manager openclaw"
    echo "Manager env (optional): MANAGER_TELEGRAM_BOT_TOKEN, OPENCLAW_TELEGRAM_BOT_TOKEN"
    exit 1
    ;;
esac
